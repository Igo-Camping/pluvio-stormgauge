{
  "_description": "Synthetic IFD + station fixtures for calcAEP golden tests. Not a real BoM station; values chosen to exercise every bracket of the AEP interpolation.",
  "synthetic_station": {
    "station_id": "test-aep-001",
    "name": "Test AEP Station 1"
  },
  "synthetic_ifd": {
    "5":   {"63.2%": 1.5, "50%": 2.0, "20%": 3.0, "10%": 4.0, "5%": 5.5, "2%": 7.0, "1%": 8.5},
    "15":  {"63.2%": 3.0, "50%": 4.0, "20%": 6.0, "10%": 8.0, "5%": 11.0, "2%": 14.0, "1%": 17.0},
    "30":  {"63.2%": 4.5, "50%": 6.0, "20%": 9.0, "10%": 12.0, "5%": 16.5, "2%": 21.0, "1%": 25.5},
    "60":  {"63.2%": 6.0, "50%": 8.0, "20%": 12.0, "10%": 16.0, "5%": 22.0, "2%": 28.0, "1%": 34.0},
    "180": {"63.2%": 12.0, "50%": 16.0, "20%": 24.0, "10%": 32.0, "5%": 44.0, "2%": 56.0, "1%": 68.0},
    "1440":{"63.2%": 30.0, "50%": 40.0, "20%": 60.0, "10%": 80.0, "5%": 110.0, "2%": 140.0, "1%": 170.0}
  },
  "test_cases": [
    {"label": "zero_depth", "duration": 60, "depth_mm": 0, "expected_meta": "special-case very frequent"},
    {"label": "below_all_thresholds", "duration": 60, "depth_mm": 4.0, "expected_meta": "less than 6.0 mm/h (63.2% AEP) -> >63.2%"},
    {"label": "exact_50pct", "duration": 60, "depth_mm": 8.0, "expected_meta": "exactly at 50% AEP threshold"},
    {"label": "mid_bracket_50_to_20", "duration": 60, "depth_mm": 10.0, "expected_meta": "between 50% (8.0) and 20% (12.0)"},
    {"label": "exact_20pct", "duration": 60, "depth_mm": 12.0, "expected_meta": "exactly at 20% AEP"},
    {"label": "mid_bracket_5_to_2", "duration": 60, "depth_mm": 25.0, "expected_meta": "between 5% (22.0) and 2% (28.0)"},
    {"label": "above_all_thresholds", "duration": 60, "depth_mm": 50.0, "expected_meta": "above 1% (34.0) -> tail extrapolation"},
    {"label": "extreme_above_thresholds", "duration": 60, "depth_mm": 100.0, "expected_meta": "far above 1% -> very large ARI"},
    {"label": "different_duration_15min", "duration": 15, "depth_mm": 10.0, "expected_meta": "uses 15-min IFD row, between 50% and 20%"},
    {"label": "long_duration_24h", "duration": 1440, "depth_mm": 100.0, "expected_meta": "uses 24-h IFD row, between 5% and 2%"},
    {"label": "missing_duration", "duration": 120, "depth_mm": 10.0, "expected_meta": "no 120-min row in IFD -> null"},
    {"label": "missing_station", "station_override": "no-such-station", "duration": 60, "depth_mm": 10.0, "expected_meta": "ifdCache miss -> null"}
  ]
}
